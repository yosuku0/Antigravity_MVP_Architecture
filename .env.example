# NIM-Kinetic Meta-Agent MVP — Environment Variables
# Copy this file to `.env` and fill in your actual values.
# NEVER commit `.env` to git. It contains secrets.

# NVIDIA NIM API Key (Primary)
# Obtain at: https://build.nvidia.com → Get API Key
NVIDIA_API_KEY=nvapi-your-key-here

# NIM API Key (Backward-compatible fallback — deprecated)
# Only used if NVIDIA_API_KEY is not set.
NIM_API_KEY=

# Paid Provider Keys (Optional for MVP — core loop uses NIM + Ollama)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
KIMI_API_KEY=

# Ollama Local Endpoint
OLLAMA_BASE_URL=http://localhost:11434

# Slack Integration (Socket Mode)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_CHANNEL_ID=C12345678
SLACK_ADMIN_USER_IDS=U12345678,U87654321

# E2B Sandbox API Key (optional ? enables safe code execution)
# Get free key at: https://e2b.dev
E2B_API_KEY=
